44102,-0.02436946,-0.02137136,0.19762668,0.04023435,-0.0266557,0.01909283,-0.00682976,0.00553422,0.0689209,0.0447852,-0.03823726,0.05785932,0.08134328,0.03993407,-0.01001758,-0.03710179,-0.01435288,0.04312217,0.03016021,0.00804418,0.0104779,0.06303763,-0.07174759,0.01081763,0.09216627,0.02612154,-0.10944916,-0.03430167,-0.04318567,-0.01592387,-0.0218423,-0.02899809,0.00565335,0.06095433,0.04422317,0.07597778,0.03870685,0.05180752,-0.107628,0.01594059,0.0202158,-0.03693045,0.01834156,0.00999733,0.03895599],"last_embed":{"hash":"iyp3lv","tokens":372}}},"last_read":{"hash":"iyp3lv","at":1751263464922},"class_name":"SmartSource","last_import":{"mtime":1745132929359,"size":6025,"at":1751263454266,"hash":"iyp3lv"},"blocks":{"#---frontmatter---":[1,10],"#飛び立つ君の背を見上げる 響け！ ユーフォニアム":[11,129],"#飛び立つ君の背を見上げる 響け！ ユーフォニアム#Metadata":[12,17],"#飛び立つ君の背を見上げる 響け！ ユーフォニアム#Metadata#{1}":[13,13],"#飛び立つ君の背を見上げる 響け！ ユーフォニアム#Metadata#{2}":[14,14],"#飛び立つ君の背を見上げる 響け！ ユーフォニアム#Metadata#{3}":[15,15],"#飛び立つ君の背を見上げる 響け！ ユーフォニアム#Metadata#{4}":[16,17],"#飛び立つ君の背を見上げる 響け！ ユーフォニアム#Highlights":[18,129],"#飛び立つ君の背を見上げる 響け！ ユーフォニアム#Highlights#{1}":[19,129]},"outlinks":[{"title":"武田綾乃","target":"https://www.amazon.comundefined","line":13},{"title":"Kindle link","target":"kindle://book?action=open&asin=B08R3NMW4F","line":16},{"title":"うっかり太陽を直視してしまったときのような、濃縮したまぶしさが網膜を焼き切ろうとする","target":"うっかり太陽を直視してしまったときのような、濃縮したまぶしさが網膜を焼き切ろうとする","line":19},{"title":"自分を形作る輪郭だけが明瞭で、それ以外の何もかもが他人事みたいにぼやけて見える。","target":"自分を形作る輪郭だけが明瞭で、それ以外の何もかもが他人事みたいにぼやけて見える。","line":22},{"title":"夏紀だって一度はなってみたい、学校が好きな人間に","target":"夏紀だって一度はなってみたい、学校が好きな人間に","line":27},{"title":"出たいかどうかと出られるかどうかは別の話だと私は思うけど","target":"出たいかどうかと出られるかどうかは別の話だと私は思うけど","line":30},{"title":"746","target":"kindle://book?action=open&asin=B08R3NMW4F&location=746","line":35},{"title":"「自分が第一」の主張をぶつけてくるあすかよりも、香織のほうが夏紀は怖い。","target":"「自分が第一」の主張をぶつけてくるあすかよりも、香織のほうが夏紀は怖い。","line":38},{"title":"909","target":"kindle://book?action=open&asin=B08R3NMW4F&location=909","line":43},{"title":"それを衝動と呼ぶにはいささか理性が残りすぎていた。","target":"それを衝動と呼ぶにはいささか理性が残りすぎていた。","line":48},{"title":"ずるり。四つに区切られた心臓の小部屋から、無自覚に抱き続けていた本音が漏れた。","target":"ずるり。四つに区切られた心臓の小部屋から、無自覚に抱き続けていた本音が漏れた。","line":51},{"title":"1292","target":"kindle://book?action=open&asin=B08R3NMW4F&location=1292","line":54},{"title":"出遅れた夏紀はとりあえずピースすることにした。","target":"出遅れた夏紀はとりあえずピースすることにした。","line":59},{"title":"1497","target":"kindle://book?action=open&asin=B08R3NMW4F&location=1497","line":65},{"title":"それはやる気と呼ぶにはささやかすぎたが、気のせいだと断じるにはあまりに熱を持ちすぎていた。","target":"それはやる気と呼ぶにはささやかすぎたが、気のせいだと断じるにはあまりに熱を持ちすぎていた。","line":68},{"title":"もしも自分の背中から翼が生えたって、夏紀はきっと空を飛べない。","target":"もしも自分の背中から翼が生えたって、夏紀はきっと空を飛べない。","line":73},{"title":"2270","target":"kindle://book?action=open&asin=B08R3NMW4F&location=2270","line":76},{"title":"当然の顔で肯定するには、夏紀の面の皮の厚さが少しばかり足りなかった。","target":"当然の顔で肯定するには、夏紀の面の皮の厚さが少しばかり足りなかった。","line":81},{"title":"でも、頼るものを分散化しようと思ったの。いろんなものを好きになって、いろんなものを居場所にして……。","target":"でも、頼るものを分散化しようと思ったの。いろんなものを好きになって、いろんなものを居場所にして……。","line":86},{"title":"2563","target":"kindle://book?action=open&asin=B08R3NMW4F&location=2563","line":91},{"title":"まぶしい暗闇のなかで腑抜けた極彩色が飛び散った。","target":"まぶしい暗闇のなかで腑抜けた極彩色が飛び散った。","line":96},{"title":"べつに、寂しいわけじゃない。悲しいわけでもない。ただ、 虚しい。","target":"べつに、寂しいわけじゃない。悲しいわけでもない。ただ、 虚しい。","line":101},{"title":"2784","target":"kindle://book?action=open&asin=B08R3NMW4F&location=2784","line":104},{"title":"冷めたフライドポテトをつまみ、優子はその端を小さくかじった。","target":"冷めたフライドポテトをつまみ、優子はその端を小さくかじった。","line":109},{"title":"月って欠けるから好きだな、とふと思う。","target":"月って欠けるから好きだな、とふと思う。","line":114},{"title":"2936","target":"kindle://book?action=open&asin=B08R3NMW4F&location=2936","line":119},{"title":"自分がいかに凡人か突きつけられ、呼吸が一瞬止まるから。","target":"自分がいかに凡人か突きつけられ、呼吸が一瞬止まるから。","line":124}],"metadata":{"kindle-sync":{"bookId":"55714","title":"飛び立つ君の背を見上げる 響け！ ユーフォニアム","author":"武田綾乃","asin":"B08R3NMW4F","lastAnnotatedDate":"2023-02-16","bookImageUrl":"https://m.media-amazon.com/images/I/81UGcrszYKL._SY160.jpg","highlightsCount":25}},"