17536469,-0.01414099,-0.0081747,-0.01723654,0.02673128,0.00887139,0.04337502,0.0176495,-0.059888,-0.01982044,0.09839225,0.00464276,0.03784297,0.00902488,-0.0333227,-0.01211616,0.03473718,-0.02205355,-0.04978962,0.08765446,0.0108583,0.00297175,0.07684739,0.03168716,-0.05461176,-0.08389565,-0.02599697,-0.00811909,-0.05282396,0.04196914,0.01132211,0.01097139,0.02660088,0.02650663,0.01315707,-0.02991983,-0.0152083,-0.01838654,-0.01389886,0.02394802,0.04331826,-0.01547874,0.06239102],"last_embed":{"hash":"104b227","tokens":463}}},"text":null,"length":0,"last_read":{"hash":"104b227","at":1751263460388},"key":"110_MOC/Lexicon_MOC.md##Rhetoric","lines":[42,82],"size":2362,"outlinks":[{"title":"「自分が第一」の主張をぶつけてくるあすかよりも、香織のほうが夏紀は怖い。","target":"「自分が第一」の主張をぶつけてくるあすかよりも、香織のほうが夏紀は怖い。","line":4},{"title":"あそこまでいけば誰だって評価してくれる。やから、文句を言うならあのレベルになってからかなって思う","target":"あそこまでいけば誰だって評価してくれる。やから、文句を言うならあのレベルになってからかなって思う","line":5},{"title":"アタシはさ、特別になりたい","target":"アタシはさ、特別になりたい","line":6},{"title":"アタシは悔しい。めっちゃ悔しいねん","target":"アタシは悔しい。めっちゃ悔しいねん","line":7},{"title":"アタシは勝ちたい。立華にも、龍聖にも、どの学校にも。北宇治が一番やって言われたい。","target":"アタシは勝ちたい。立華にも、龍聖にも、どの学校にも。北宇治が一番やって言われたい。","line":8},{"title":"いまというこの瞬間を容器に詰め込んで、冷凍保存できればいいのに。","target":"いまというこの瞬間を容器に詰め込んで、冷凍保存できればいいのに。","line":9},{"title":"うっかり太陽を直視してしまったときのような、濃縮したまぶしさが網膜を焼き切ろうとする","target":"うっかり太陽を直視してしまったときのような、濃縮したまぶしさが網膜を焼き切ろうとする","line":10},{"title":"ずるり。四つに区切られた心臓の小部屋から、無自覚に抱き続けていた本音が漏れた。","target":"ずるり。四つに区切られた心臓の小部屋から、無自覚に抱き続けていた本音が漏れた。","line":11},{"title":"プチトマトを箸でつかもうとすると、その真っ赤な球体は滑るようにしてランチョンマットの上に転がった。","target":"プチトマトを箸でつかもうとすると、その真っ赤な球体は滑るようにしてランチョンマットの上に転がった。","line":12},{"title":"べつに、寂しいわけじゃない。悲しいわけでもない。ただ、 虚しい。","target":"べつに、寂しいわけじゃない。悲しいわけでもない。ただ、 虚しい。","line":13},{"title":"マイナスをゼロにする努力は楽しくない","target":"マイナスをゼロにする努力は楽しくない","line":14},{"title":"まぶしい暗闇のなかで腑抜けた極彩色が飛び散った。","target":"まぶしい暗闇のなかで腑抜けた極彩色が飛び散った。","line":15},{"title":"もしも自分の背中から翼が生えたって、夏紀はきっと空を飛べない。","target":"もしも自分の背中から翼が生えたって、夏紀はきっと空を飛べない。","line":16},{"title":"私は、あすか先輩と本番に出たい。なんでそれじゃダメなんですか","target":"私は、あすか先輩と本番に出たい。なんでそれじゃダメなんですか","line":17},{"title":"結果が出えへんかったら、努力ってなかったことにされてしまうん？　あのときのうちらの演奏、ほんまにほかの金賞の学校より劣ってた？","target":"結果が出えへんかったら、努力ってなかったことにされてしまうん？　あのときのうちらの演奏、ほんまにほかの金賞の学校より劣ってた？","line":18},{"title":"嫌でも大人になっちゃうのに、子供のときから大人ぶる必要なんて全然ない。","target":"嫌でも大人になっちゃうのに、子供のときから大人ぶる必要なんて全然ない。","line":19},{"title":"根拠のない確信を抱きながら、久美子はマウスピースに息を吹き込む。楽器はブルブルと震え、それからゆっくりと芯の通った音を吐き出した","target":"根拠のない確信を抱きながら、久美子はマウスピースに息を吹き込む。楽器はブルブルと震え、それからゆっくりと芯の通った音を吐き出した","line":20},{"title":"月って欠けるから好きだな、とふと思う。","target":"月って欠けるから好きだな、とふと思う。","line":21},{"title":"三年生ほど滝先生を絶対視することはできない。","target":"三年生ほど滝先生を絶対視することはできない。","line":22},{"title":"出たいかどうかと出られるかどうかは別の話だと私は思うけど","target":"出たいかどうかと出られるかどうかは別の話だと私は思うけど","line":23},{"title":"出遅れた夏紀はとりあえずピースすることにした。","target":"出遅れた夏紀はとりあえずピースすることにした。","line":24},{"title":"自分を形作る輪郭だけが明瞭で、それ以外の何もかもが他人事みたいにぼやけて見える。","target":"自分を形作る輪郭だけが明瞭で、それ以外の何もかもが他人事みたいにぼやけて見える。","line":25},{"title":"中世古香織_ソロパートオーディション","target":"中世古香織_ソロパートオーディション","line":26},{"title":"仲がいいと思っていたはずの友達がほかの子と座っていたり、順風満帆に座れるはずだった偶数グループが補助席のせいで分裂騒動を起こしたり","target":"仲がいいと思っていたはずの友達がほかの子と座っていたり、順風満帆に座れるはずだった偶数グループが補助席のせいで分裂騒動を起こしたり","line":27},{"title":"薄氷の上に立っているような、そんな気分。","target":"薄氷の上に立っているような、そんな気分。","line":28},{"title":"冷めたフライドポテトをつまみ、優子はその端を小さくかじった。","target":"冷めたフライドポテトをつまみ、優子はその端を小さくかじった。","line":29},{"title":"綺麗に折り畳まれていたはずの雑巾がぐちゃりと乱れ、内側に隠していたはずの汚れをあらわにしていた","target":"綺麗に折り畳まれていたはずの雑巾がぐちゃりと乱れ、内側に隠していたはずの汚れをあらわにしていた","line":30},{"title":"当然の顔で肯定するには、夏紀の面の皮の厚さが少しばかり足りなかった。","target":"当然の顔で肯定するには、夏紀の面の皮の厚さが少しばかり足りなかった。","line":31},{"title":"未練を殺すには短すぎたが、将来を誓い合うには充分だった。","target":"未練を殺すには短すぎたが、将来を誓い合うには充分だった。","line":32},{"title":"それはやる気と呼ぶにはささやかすぎたが、気のせいだと断じるにはあまりに熱を持ちすぎていた。","target":"それはやる気と呼ぶにはささやかすぎたが、気のせいだと断じるにはあまりに熱を持ちすぎていた。","line":33},{"title":"それを衝動と呼ぶにはいささか理性が残りすぎていた。","target":"それを衝動と呼ぶにはいささか理性が残りすぎていた。","line":34}],"class_name":"SmartBlock","last_embed":{"hash":"104b227","at":1751263460388}},
