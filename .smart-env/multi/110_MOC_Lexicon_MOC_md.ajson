0466294,0.16968937,-0.01238798,-0.00569587,-0.019085,0.02500976,0.0066311,0.04170021,0.01592203,-0.05822995,-0.02590098,0.09871406,0.00573845,0.03579718,0.00431556,-0.0288761,-0.00965716,0.03419263,-0.02079487,-0.06237483,0.08468502,0.00952358,0.00316157,0.07433705,0.03684077,-0.05204692,-0.08140395,-0.02892446,-0.00379053,-0.05317141,0.04774485,0.01109078,0.01179632,0.03096424,0.03211535,0.0159629,-0.03254761,-0.01832694,-0.01280567,-0.01026621,0.03319325,0.0433797,-0.01419395,0.0635378],"last_embed":{"hash":"1uktx94","tokens":464}}},"text":null,"length":0,"last_read":{"hash":"1uktx94","at":1751263460402},"key":"110_MOC/Lexicon_MOC.md##Rhetoric#武田綾乃","lines":[44,82],"size":2349,"outlinks":[{"title":"「自分が第一」の主張をぶつけてくるあすかよりも、香織のほうが夏紀は怖い。","target":"「自分が第一」の主張をぶつけてくるあすかよりも、香織のほうが夏紀は怖い。","line":2},{"title":"あそこまでいけば誰だって評価してくれる。やから、文句を言うならあのレベルになってからかなって思う","target":"あそこまでいけば誰だって評価してくれる。やから、文句を言うならあのレベルになってからかなって思う","line":3},{"title":"アタシはさ、特別になりたい","target":"アタシはさ、特別になりたい","line":4},{"title":"アタシは悔しい。めっちゃ悔しいねん","target":"アタシは悔しい。めっちゃ悔しいねん","line":5},{"title":"アタシは勝ちたい。立華にも、龍聖にも、どの学校にも。北宇治が一番やって言われたい。","target":"アタシは勝ちたい。立華にも、龍聖にも、どの学校にも。北宇治が一番やって言われたい。","line":6},{"title":"いまというこの瞬間を容器に詰め込んで、冷凍保存できればいいのに。","target":"いまというこの瞬間を容器に詰め込んで、冷凍保存できればいいのに。","line":7},{"title":"うっかり太陽を直視してしまったときのような、濃縮したまぶしさが網膜を焼き切ろうとする","target":"うっかり太陽を直視してしまったときのような、濃縮したまぶしさが網膜を焼き切ろうとする","line":8},{"title":"ずるり。四つに区切られた心臓の小部屋から、無自覚に抱き続けていた本音が漏れた。","target":"ずるり。四つに区切られた心臓の小部屋から、無自覚に抱き続けていた本音が漏れた。","line":9},{"title":"プチトマトを箸でつかもうとすると、その真っ赤な球体は滑るようにしてランチョンマットの上に転がった。","target":"プチトマトを箸でつかもうとすると、その真っ赤な球体は滑るようにしてランチョンマットの上に転がった。","line":10},{"title":"べつに、寂しいわけじゃない。悲しいわけでもない。ただ、 虚しい。","target":"べつに、寂しいわけじゃない。悲しいわけでもない。ただ、 虚しい。","line":11},{"title":"マイナスをゼロにする努力は楽しくない","target":"マイナスをゼロにする努力は楽しくない","line":12},{"title":"まぶしい暗闇のなかで腑抜けた極彩色が飛び散った。","target":"まぶしい暗闇のなかで腑抜けた極彩色が飛び散った。","line":13},{"title":"もしも自分の背中から翼が生えたって、夏紀はきっと空を飛べない。","target":"もしも自分の背中から翼が生えたって、夏紀はきっと空を飛べない。","line":14},{"title":"私は、あすか先輩と本番に出たい。なんでそれじゃダメなんですか","target":"私は、あすか先輩と本番に出たい。なんでそれじゃダメなんですか","line":15},{"title":"結果が出えへんかったら、努力ってなかったことにされてしまうん？　あのときのうちらの演奏、ほんまにほかの金賞の学校より劣ってた？","target":"結果が出えへんかったら、努力ってなかったことにされてしまうん？　あのときのうちらの演奏、ほんまにほかの金賞の学校より劣ってた？","line":16},{"title":"嫌でも大人になっちゃうのに、子供のときから大人ぶる必要なんて全然ない。","target":"嫌でも大人になっちゃうのに、子供のときから大人ぶる必要なんて全然ない。","line":17},{"title":"根拠のない確信を抱きながら、久美子はマウスピースに息を吹き込む。楽器はブルブルと震え、それからゆっくりと芯の通った音を吐き出した","target":"根拠のない確信を抱きながら、久美子はマウスピースに息を吹き込む。楽器はブルブルと震え、それからゆっくりと芯の通った音を吐き出した","line":18},{"title":"月って欠けるから好きだな、とふと思う。","target":"月って欠けるから好きだな、とふと思う。","line":19},{"title":"三年生ほど滝先生を絶対視することはできない。","target":"三年生ほど滝先生を絶対視することはできない。","line":20},{"title":"出たいかどうかと出られるかどうかは別の話だと私は思うけど","target":"出たいかどうかと出られるかどうかは別の話だと私は思うけど","line":21},{"title":"出遅れた夏紀はとりあえずピースすることにした。","target":"出遅れた夏紀はとりあえずピースすることにした。","line":22},{"title":"自分を形作る輪郭だけが明瞭で、それ以外の何もかもが他人事みたいにぼやけて見える。","target":"自分を形作る輪郭だけが明瞭で、それ以外の何もかもが他人事みたいにぼやけて見える。","line":23},{"title":"中世古香織_ソロパートオーディション","target":"中世古香織_ソロパートオーディション","line":24},{"title":"仲がいいと思っていたはずの友達がほかの子と座っていたり、順風満帆に座れるはずだった偶数グループが補助席のせいで分裂騒動を起こしたり","target":"仲がいいと思っていたはずの友達がほかの子と座っていたり、順風満帆に座れるはずだった偶数グループが補助席のせいで分裂騒動を起こしたり","line":25},{"title":"薄氷の上に立っているような、そんな気分。","target":"薄氷の上に立っているような、そんな気分。","line":26},{"title":"冷めたフライドポテトをつまみ、優子はその端を小さくかじった。","target":"冷めたフライドポテトをつまみ、優子はその端を小さくかじった。","line":27},{"title":"綺麗に折り畳まれていたはずの雑巾がぐちゃりと乱れ、内側に隠していたはずの汚れをあらわにしていた","target":"綺麗に折り畳まれていたはずの雑巾がぐちゃりと乱れ、内側に隠していたはずの汚れをあらわにしていた","line":28},{"title":"当然の顔で肯定するには、夏紀の面の皮の厚さが少しばかり足りなかった。","target":"当然の顔で肯定するには、夏紀の面の皮の厚さが少しばかり足りなかった。","line":29},{"title":"未練を殺すには短すぎたが、将来を誓い合うには充分だった。","target":"未練を殺すには短すぎたが、将来を誓い合うには充分だった。","line":30},{"title":"それはやる気と呼ぶにはささやかすぎたが、気のせいだと断じるにはあまりに熱を持ちすぎていた。","target":"それはやる気と呼ぶにはささやかすぎたが、気のせいだと断じるにはあまりに熱を持ちすぎていた。","line":31},{"title":"それを衝動と呼ぶにはいささか理性が残りすぎていた。","target":"それを衝動と呼ぶにはいささか理性が残りすぎていた。","line":32}],"class_name":"SmartBlock","last_embed":{"hash":"1uktx94","at":1751263460402}},
