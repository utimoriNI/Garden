filters:
  and:
    - file.folder == "300_Input"
views:
  - type: table
    name: View
    filters:
      and:
        - file.hasTag("🎁Topic/Life")
    order:
      - file.name
      - url
      - source
    sort: []
    cardSize: 260
    imageFit: contain
    imageAspectRatio: 0.3
    columnSize:
      file.name: 910
      note.url: 329
    rowHeight: medium
